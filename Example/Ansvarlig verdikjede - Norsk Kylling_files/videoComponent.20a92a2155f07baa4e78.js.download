(()=>{const e=document.querySelectorAll(".video__component-container");var t=document.documentElement;e.forEach((e=>{const s=e.querySelector("video");if(!s)return;const a=window.innerWidth<=768,c=a?s.dataset.vimeoMobileSrc:s.dataset.vimeoSrc,o=a?s.dataset.posterMobile:s.dataset.posterDesktop,r=document.createElement("source");r.src=c,r.type="video/mp4",s.appendChild(r),o&&s.setAttribute("poster",o),s.hasAttribute("autoplay")&&new IntersectionObserver(((e,t)=>{e.forEach((e=>{e.isIntersecting&&(setTimeout((()=>{s.play().catch((e=>console.warn("Autoplay failed:",e)))}),500),t.unobserve(s))}))}),{threshold:.5}).observe(s);const d=e.querySelector(".play-btn");d&&d.addEventListener("click",(async e=>{if(e.preventDefault(),s.paused)return await s.play(),void d.classList.remove("paused");s.pause(),d.classList.add("paused")}));const n=e.querySelector(".mute-btn");n&&n.addEventListener("click",(e=>{e.preventDefault(),s.muted?(s.muted=!1,n.classList.remove("muted")):(s.muted=!0,n.classList.add("muted"))}));const i=e.querySelector(".play-full-btn");i&&i.addEventListener("click",(async e=>{if(e.preventDefault(),s.paused)return await s.play(),void d.classList.remove("paused");s.pause(),d.classList.add("paused"),t.classList.add("video-active")}));const l=document.querySelector(".close-btn");l&&l.addEventListener("click",(async e=>{s.paused&&(await s.play(),d.classList.remove("paused")),t.classList.remove("video-active")}))}))})();