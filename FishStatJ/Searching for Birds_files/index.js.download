,this.lastAreaError=t,isNaN(e)||(n=this.lastGrowth,this.lastGrowth=this.lastAreaError>=e?1:-1),isNaN(n)||this.growthChanges.unshift(this.lastGrowth!=n),this.growthChanges.length>this.growthChangesLength&&this.growthChanges.pop(),this},Uf.prototype.ratio=function(){var t=0;if(this.growthChanges.length<this.growthChangesLength)return 0;if(this.lastAreaError>this.totalAvailableArea/10)return 0;for(var e=0;e<this.growthChangesLength;e++)this.growthChanges[e]&&(t+=this.growthChangeWeights[e]);return t/this.growthChangeWeightsSum},Yf.prototype.name="d3VoronoiMapError",Yf.prototype=new Error,document.getElementById("ai-chatbot-container");const ad=document.getElementById("ai-chatbot-messages"),od=document.getElementById("ai-user-input"),sd=document.getElementById("ai-send-btn");let ld=[],cd=[],ud=[];const hd={breeding_system:{coop:"cooperative: two or more females simultaneously breed in the same nest with or without non-breeding helper",polygam:"polygynandry: two or more males mate with two or more females exclusively",promisc:"promiscuity: males and females mate indiscriminately",lek:"lekking: females survey the males' competitive displays",polyandr:"polyandry: one female mates with more than one male",polygyn:"polygyny: one male mates with more than one female",monog:"monogamy: one male mates with one female"},nest_type:{no:"laying eggs on bare ground",parasitism:"does not require building a nest, but is dependent on other species' nests presence",scrape:"a simple depression with a rim to prevent eggs from rolling",crevice:"a crack in a cliff or between rocks",burrow:"chamber in the end of a burrowed tunnel",cavity:"excavated or natural cavity in a limb or trunk of a tree",platform:"structure large enough for a bird to land",saucer:"shallow cup with a small rim built of small branches and other materials",cup:"hemispherical nest with a large rim",spherical:"enclosed with a small entrance",chamber:"spherical nest hidden within a substrate",oven:"a specific chamber with an explicit roof and small entrance",gourd:"a chamber made of clay and saliva, typically attached to a vertical surface",pendant:"an elongate sack suspended from a branch"},development:{pre2:"mobile, downy, follow parents, find food",pre3:"mobile, downy, follow parents, are shown food by parents",pre4:"mobile, downy, follow parents, being fed",semipre:"mobile, remain at rest, being fed",semialt1:"immobile, downy, eyes open, being fed",semialt2:"immobile, downy, eyes closed, being fed",alt:"immobile, downless, eyes closed, being fed"},variables:["bird","type","gt_interest","gt_states_count","gt_rank","ebird_n_obs","ebird_rank","population","pop_rank","introduced","urban","habitat","food","behavior","nest_location","nest_type","eggs_low","eggs_high","dev_at_hatch","breeding_interval","breeding_season","breeding_start","breeding_end","breeding_system","nest_paratism","nesting_attempts","hatching_days","fledging_days","independence_days","max_life","weight","conservation_status","included","included_full","included_rank"]};async function fd(t){try{const e={message:t,history:ld,systemInstruction:'You are an expert ornithologist and birding companion. \n    Your goal is to help users identify birds or learn about specific US bird species.\n    \n    Context: You are embedded in a data visualization story about US bird search trends.\n    Users might find a bird in the story and ask you about it.\n    \n    I have already checked my local US bird database for the user\'s message.\n    - If I found a bird, I have already shown the card to the user and I will ask you to summarize the data.\n    - If I did NOT find a bird, it means the user\'s query did not match any bird in my 600+ US bird list.\n\n    **IMPORTANT**: Always place all the bird names in your response in **bold**.\n\n    **TASK: BIRD DATA SUMMARY**\n    When I provide raw bird data (starting with "Here is the data for..."), you must summarize it following these rules:\n    1. **Style**: Friendly, storytelling prose. Do NOT use lists. Do NOT thank me for the data or mention the data source—act as if this knowledge is your own.\n    2. **Structure**: Make sure to always return 3 paragraphs. With the first containing the ranking information, the 2nd the food and behavior information and the 3rd at least including the breeding season information. But only if this information was included in the text supplied to you.\n       - Paragraph 1: Google Trends results/rankings (if available), eBird observations/rankings, and population results/rankings (if available).\n       - Paragraph 2: Habitat, behavior, conservation status, and other interesting facts (you may add well-known facts if you are certain).\n       - Paragraph 3: Breeding and nesting information (if available, if not, no need to mention that you don\'t have this information).\n    3. **Formatting**:\n       - **Bold** all statistics, metadata, and numerical rankings (e.g., **386th** or "they eat **fruit**", "breeding seasons runs from **June** to **August**").\n       - Abbreviate large numbers to short forms (e.g., \'1.2 million\' for 1200000).\n    4. **Length**: Keep it engaging but concise.\n\n    **OTHER CAPABILITIES:**\n    1.  **Identification**: If the user describes a bird (color, size, location) or asks "What bird is this?", suggest 2-3 most likely candidates found in the USA.\n        - You MUST output a specific JSON object for this.\n        - **JSON format**:\n        ```json\n        {\n            "action": "identify",\n            "birds": ["Bird Common Name 1", "Bird Common Name 2", "Bird Common Name 3"],\n            "text": "Your conversational response here. Explain WHY you suggest these birds. Place bird species names in **bold**. IMPORTANT: Use single quotes (\') for any internal quotes to keep the JSON valid."\n        }\n        ```\n        - Do not output any other text outside this JSON block for identification queries.\n        \n    2.  **Handling Unknowns**: If the user asks about a bird by name (e.g. "Tell me about the EmperorPenguin" or "Tell me about the Cedar Waxing") and I sent this text to you, it means IT WAS NOT FOUND in the US database. \n        - If it\'s a non-US bird (like "Emperor Penguin"), explain that it isn\'t found in the US, but you can mention where the bird is found and suggest some US birds that are similar.\n        - Or if it does not seem to be a full bird species (like "Hawk"), explain that this seems to be a more general bird group and suggest two or three of the most likely US bird species.\n        - Or if it was misspelled (like "Cedar Waxing"), suggest the correct US bird name. In that case YOU MUST OUTPUT JSON to trigger a database lookup for the bird name you think is the correct one. See below for the JSON format\n    \n    **CRITICAL INSTRUCTION FOR MISSPELLED BIRD NAMES ONLY**:\n    If and ONLY IF the user asks for a SPECIFIC bird species that was seemingly misspelled but you suggest a correct US bird name, output a JSON object in this format:\n    ```json\n    { "action": "lookup", "bird": "Exact Bird Common Name", "text": "Explain why you think this is the correct bird name. Use single quotes (\') for internal quotes." }\n    ```\n    Do not output any other text with this JSON. I will fetch the data and feed it back to you to summarize.\n\n    Tone: Friendly, enthusiastic, educational, but concise. Use emojis occasionally 🐦. Never say things like "The user asked for" or refer to "the user", this should seem like a conversation between you and the one that inputs the text.\n\n    If a user asks a question that has absolutely nothing to do with birds, kindly reply that you only know about birds and that you can\'t help them with this question.\n\n    **CRITICAL: JSON Validity**\n    When outputting JSON, you MUST ensure it is valid. If you need to use quotes inside the "text" field, use single quotes (\') instead of double quotes (") to avoid breaking the JSON string.\n    '},n=await fetch("/.netlify/functions/